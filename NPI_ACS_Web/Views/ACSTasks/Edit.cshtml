@model NPI_ACS_Web.Models.ACSTask

@{
ViewData["Title"] = "Edit Task";
}

<h2>Edit Task</h2>

<form asp-action="Edit" method="post" enctype="multipart/form-data">

```
@Html.AntiForgeryToken()

<input type="hidden" asp-for="Id" />

<div asp-validation-summary="ModelOnly" class="text-danger"></div>

<div class="form-group mb-3">
    <label asp-for="Project"></label>
    <input asp-for="Project" class="form-control"/>
</div>

<div class="form-group mb-3">
    <label asp-for="ODM"></label>
    <input asp-for="ODM" class="form-control"/>
</div>

<div class="form-group mb-3">
    <label asp-for="Product"></label>
    <input asp-for="Product" class="form-control"/>
</div>

<div class="form-group mb-3">
    <label asp-for="Model"></label>
    <input asp-for="Model" class="form-control"/>
</div>

<div class="form-group mb-3">
    <label asp-for="Question"></label>
    <textarea asp-for="Question" class="form-control"></textarea>
</div>

<div class="form-group mb-3">
    <label asp-for="ActionDetail"></label>
    <textarea asp-for="ActionDetail" class="form-control"></textarea>
</div>

<div class="form-group mb-3">
    <label asp-for="FourM">4M</label>
    <input asp-for="FourM" class="form-control"/>
</div>

<div class="form-group mb-3">
    <label asp-for="NeolyncPIC"></label>
    <input asp-for="NeolyncPIC" class="form-control"/>
</div>

<div class="form-group mb-3">
    <label asp-for="CustomerPIC"></label>
    <input asp-for="CustomerPIC" class="form-control"/>
</div>

<div class="form-group mb-3">
    <label asp-for="Priority"></label>
    <select asp-for="Priority" class="form-control">
        <option>Low</option>
        <option>Medium</option>
        <option>High</option>
    </select>
</div>

<div class="form-group mb-3">
    <label asp-for="Status"></label>
    <select asp-for="Status" class="form-control">
        <option>Open</option>
        <option>Ongoing</option>
        <option>Closed</option>
    </select>
</div>

<div class="form-group mb-3">
    <label asp-for="StartDate"></label>
    <input asp-for="StartDate" type="date" class="form-control"/>
</div>

<div class="form-group mb-3">
    <label asp-for="DueDate"></label>
    <input asp-for="DueDate" type="date" class="form-control"/>
</div>

<div class="form-group mb-3">
    <label asp-for="ActualCloseDate"></label>
    <input asp-for="ActualCloseDate" type="date" class="form-control"/>
</div>

<div class="form-group mb-3">
    <label asp-for="Remarks"></label>
    <textarea asp-for="Remarks" class="form-control"></textarea>
</div>

<hr/>

<h5>Attachment</h5>

@if (!string.IsNullOrEmpty(Model.AttachmentPath))
{
    <p>
        Current File:
        <a href="@Model.AttachmentPath" target="_blank">View Attachment</a>
    </p>
}

<div class="form-group mb-4">
    <input type="file" name="AttachmentFile" class="form-control"/>
</div>

<button type="submit" class="btn btn-primary">Update</button>
<a asp-action="Index" class="btn btn-secondary">Back</a>
```

</form>

@section Scripts{
@{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
